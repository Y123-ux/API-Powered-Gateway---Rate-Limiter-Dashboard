# Server
PORT=3001
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Upstream defaults
DEFAULT_UPSTREAM_URL=https://httpbin.org

# Rate Limiting Defaults
DEFAULT_MAX_TOKENS=100
DEFAULT_REFILL_RATE=10
DEFAULT_REFILL_INTERVAL_MS=1000
DEFAULT_BURST_ALLOWANCE=20

# CORS
CORS_ORIGIN=http://localhost:5173
